# nginx config example for NK Medicina Estética
# Copy to: /etc/nginx/sites-available/nkestetica
# Then: ln -s /etc/nginx/sites-available/nkestetica /etc/nginx/sites-enabled/
# Then: certbot --nginx -d nkmedicina.es -d www.nkmedicina.es

server {
    listen 80;
    server_name nkmedicina.es www.nkmedicina.es;
    # Certbot will add SSL redirect here automatically

    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
